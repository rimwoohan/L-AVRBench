From c98a4545dc7bf2bcaf1de539c4eb84784680eaa4 Mon Sep 17 00:00:00 2001
From: Alan Modra <amodra@gmail.com>
Date: Wed, 15 Apr 2020 12:39:54 +0930
Subject: [PATCH] Re: readelf: Consolidate --syms --use-dynamic with --dyn-syms

	PR 25821
	* readelf.c (get_num_dynamic_syms): Typo fix.
---
 binutils/ChangeLog | 5 +++++
 binutils/readelf.c | 2 +-
 2 files changed, 6 insertions(+), 1 deletion(-)

diff --git a/binutils/ChangeLog b/binutils/ChangeLog
index 33ca3e93e28..63e9085b7fc 100644
--- a/binutils/ChangeLog
+++ b/binutils/ChangeLog
@@ -1,3 +1,8 @@
+2020-04-15  Alan Modra  <amodra@gmail.com>
+
+	PR 25821
+	* readelf.c (get_num_dynamic_syms): Typo fix.
+
 2020-04-14  Alan Modra  <amodra@gmail.com>
 
 	* readelf.c (process_mips_specific): Free eopt and iopt.  Avoid
diff --git a/binutils/readelf.c b/binutils/readelf.c
index 9149bb8ce4d..efcd6f30e76 100644
--- a/binutils/readelf.c
+++ b/binutils/readelf.c
@@ -9997,7 +9997,7 @@ get_num_dynamic_syms (Filedata * filedata)
 	  if (chains)
 	    {
 	      free (chains);
-	      buckets = NULL;
+	      chains = NULL;
 	    }
 	  nbuckets = 0;
 	}
-- 
2.25.1

